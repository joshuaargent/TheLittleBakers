# ============================================
# NextJsTemplate Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================

# ============================================
# DATABASE (Required for Admin Dashboard)
# ============================================
# For local development with SQLite:
DATABASE_URL="file:./prisma/dev.db"

# For production (PostgreSQL) - Required for Vercel deployment:
# Get a free PostgreSQL database from:
# - Supabase: https://supabase.com
# - Neon: https://neon.tech
# - Railway: https://railway.app
# - Example: DATABASE_URL="postgresql://user:password@host:5432/database"

# ============================================
# SITE CONFIGURATION
# ============================================

# The full URL of your site (required for production)
# Include trailing slash for best results
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# SOCIAL MEDIA LINKS (Optional)
# ============================================

# GitHub Username (for code/portfolio page)
# Used for repository stats and showcase
GITHUB_USERNAME=joshuaargent

# GitHub Personal Access Token (optional)
# Get from: https://github.com/settings/tokens
# Required for higher API rate limits
GITHUB_TOKEN=

# ============================================
# YOUTUBE INTEGRATION (Optional)
# ============================================

# YouTube API Key (for video stats and subscriber counts)
# Get from: https://console.cloud.google.com/
# Enable YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ============================================
# STRAVA INTEGRATION (Optional)
# ============================================

# Strava API credentials (for running activity tracker)
# Get from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=

# ============================================
# EMAIL & NEWSLETTER (Optional)
# ============================================

# Buttondown newsletter API
# Get from: https://buttondown.com/settings/api
BUTTONDOWN_API_KEY=

# Formspree contact form
# Get from: https://formspree.io/
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# ============================================
# ANALYTICS (Optional)
# ============================================

# These are automatically configured when deploying to Vercel
# No additional setup needed

# ============================================
# SEO (Optional)
# ============================================

# Google Search Console verification
# GOOGLE_VERIFICATION_CODE=your_verification_code